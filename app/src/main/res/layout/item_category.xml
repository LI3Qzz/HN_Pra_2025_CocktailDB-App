<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/card_margin">

    <androidx.cardview.widget.CardView
        android:layout_width="@dimen/category_item_size"
        android:layout_height="@dimen/category_item_size"
        app:cardCornerRadius="@dimen/category_corner_radius"
        app:cardElevation="@dimen/card_elevation"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="@dimen/category_stroke_width"
        app:strokeColor="@color/black"
        app:cardUseCompatPadding="true">

        <ImageView
            android:id="@+id/iv_category"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/cocktail_logo"
            tools:src="@drawable/placeholder" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/card_margin"
        android:text="@string/category_placeholder"
        android:textColor="@color/black"
        android:textSize="@dimen/text_size_category"
        android:textStyle="bold"
        android:gravity="center"
        tools:text="Category Name" />

</LinearLayout> 
