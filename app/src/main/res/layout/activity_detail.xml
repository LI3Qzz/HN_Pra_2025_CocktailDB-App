<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Image Container with Overlay -->
        <FrameLayout
            android:id="@+id/imageContainer"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_200"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Background Image -->
            <ImageView
                android:id="@+id/ivCocktail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder"
                android:background="@color/black"
                android:contentDescription="@string/cocktail_image"/>

            <!-- Dark Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                />

            <!-- Back Button -->
            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="@dimen/button_size"
                android:layout_height="@dimen/button_size"
                android:layout_marginStart="@dimen/activity_horizontal_margin"
                android:layout_marginTop="@dimen/text_margin_bottom_large"
                android:src="@drawable/ic_back_arrow"
                android:background="@drawable/circle_background"
                android:padding="@dimen/button_padding"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back_button"
                app:tint="@color/black" />

            <!-- Action Buttons (Right Side) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="@dimen/activity_horizontal_margin"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivShare"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:layout_marginEnd="@dimen/activity_horizontal_margin"
                    android:src="@drawable/share_24dp_000000_fill0_wght400_grad0_opsz24"
                    android:background="@drawable/circle_background"
                    android:padding="@dimen/dp_8"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/share_to_friends"/>

                <ImageView
                    android:id="@+id/ivFavorite"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/ic_favorite_border_black_24dp"
                    android:background="@drawable/circle_background"
                    android:padding="@dimen/dp_8"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/favorite_icon"/>
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="@dimen/activity_horizontal_margin"
                android:layout_marginBottom="@dimen/dp_48"
                android:text="@string/title"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_large"
                android:textStyle="bold"
                android:shadowColor="@color/black"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3"/>

            <!-- Tags -->
            <LinearLayout
                android:id="@+id/tagsLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="@dimen/activity_horizontal_margin"
                android:layout_marginBottom="@dimen/text_margin_bottom_small"
                android:layout_marginTop="@dimen/text_margin_bottom_small"
                android:orientation="horizontal"/>

        </FrameLayout>

        <!-- Name Row -->
        <LinearLayout
            android:id="@+id/nameRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/rounded_box"
            android:padding="@dimen/activity_horizontal_margin"
            app:layout_constraintTop_toBottomOf="@id/imageContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/activity_horizontal_margin"
            android:layout_marginStart="@dimen/activity_horizontal_margin"
            android:layout_marginEnd="@dimen/activity_horizontal_margin">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/name"
                android:textColor="@color/gray"
                android:textSize="@dimen/text_size_category"/>

            <TextView
                android:id="@+id/tvCocktailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cocktail_name_placeholder"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_category"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Ingredients Title -->
        <TextView
            android:id="@+id/tvIngredientsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ingredients"
            android:textStyle="bold"
            android:textSize="@dimen/sp_18"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/nameRow"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="@dimen/large_padding"
            android:layout_marginStart="@dimen/activity_horizontal_margin"/>

        <!-- Ingredients RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_horizontal_margin"
            android:layout_marginStart="@dimen/activity_horizontal_margin"
            android:layout_marginEnd="@dimen/activity_horizontal_margin"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvIngredientsTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Description Title -->
        <TextView
            android:id="@+id/tvDescriptionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/description"
            android:textStyle="bold"
            android:textSize="@dimen/sp_18"
            android:textColor="@color/black"
            android:layout_marginTop="@dimen/large_padding"
            android:layout_marginStart="@dimen/activity_horizontal_margin"
            app:layout_constraintTop_toBottomOf="@id/recyclerView"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/instructions_placeholder"
            android:layout_marginTop="@dimen/activity_horizontal_margin"
            android:layout_marginStart="@dimen/activity_horizontal_margin"
            android:layout_marginEnd="@dimen/activity_horizontal_margin"
            android:background="@drawable/rounded_box"
            android:padding="@dimen/activity_horizontal_margin"
            android:textSize="@dimen/text_size_category"
            android:textColor="@color/gray"
            android:lineSpacingExtra="@dimen/dp_4"
            app:layout_constraintTop_toBottomOf="@id/tvDescriptionTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/buttonRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="@dimen/large_padding"
            android:layout_marginStart="@dimen/activity_horizontal_margin"
            android:layout_marginEnd="@dimen/activity_horizontal_margin"
            app:layout_constraintTop_toBottomOf="@id/tvDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnFavorite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/add_to_favorites"
                android:textColor="@color/white"
                android:background="@drawable/rounded_box"
                android:padding="@dimen/dp_8"
                android:textSize="@dimen/text_size_category"/>

            <Button
                android:id="@+id/btnShare"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/share_to_friends"
                android:textColor="@color/white"
                android:background="@drawable/rounded_box"
                android:padding="@dimen/dp_8"
                android:layout_marginStart="@dimen/text_margin_top_medium"
                android:textSize="@dimen/text_size_category"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>